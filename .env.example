# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dizee-tickets?retryWrites=true&w=majority

# Auth
ACCESS_TOKEN_SECRET=your-access-token-secret-here
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
JWT_ACCESS_TOKEN_EXPIRATION=2592000
JWT_REFRESH_TOKEN_EXPIRATION=7776000


# Redis (Upstash)
REDIS_URL=redis://default:your-redis-password@your-redis-host:6379

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain
MAILGUN_URL=https://api.mailgun.net

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# TicketSocket
TICKETSOCKET_API_URL=https://api.ticketsocket.com
TICKETSOCKET_API_KEY=your-ticketsocket-api-key
TICKETSOCKET_WEBHOOK_SECRET=your-ticketsocket-webhook-secret

# App
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# Site Protection (leave empty to disable)
SITE_PROTECTION_PASSWORD=

# Admin
ADMIN_EMAILS=eddie@dizee.com,ryan@dizee.com

# Rate Limiting
GENERAL_RATE_LIMIT=5000
AUTH_RATE_LIMIT=50
RATE_LIMIT_WINDOW_MS=900000
